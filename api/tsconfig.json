{
  "compilerOptions": {
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "target": "es2022",
    "types": ["node"]
  },
  "include": ["./**/*.ts"],
  "exclude": ["../artifacts/api-server/node_modules", "../node_modules"]
}
